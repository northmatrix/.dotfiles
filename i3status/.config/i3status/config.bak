general {
    output_format = "i3bar"
    colors = false   # disables all coloring
    interval = 1
}

order += "cpu_usage"
order += "memory"
order += "wireless _first_"
order += "ethernet _first_"
order += "volume master"
order += "time"

cpu_usage {
    format = "п‹› %usage"
}

memory {
    format = "о‰¦ %percentage_used"
}

wireless _first_ {
    format_up = "п‡« %quality"
    format_down = "у°–Є Disconnected"
}

ethernet _first_ {
        format_up = "оЅ„ %ip (%speed)"
	format_down = "оЅ„ Disconnected"
}

volume master {
    format = "пЂЁ  %volume"
    format_muted = "о»Ё Muted"
    device = "default"
    mixer = "master"
}

time {
    format = "пЂ— %H:%M:%S    пЃі %a, %b %d, %y"
}
